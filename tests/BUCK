# WASI test suite: build + multi-runtime conformance testing.
#
# Usage:
#   buck2 build //tests/...                - build all test components
#   buck2 test //tests:wasmtime            - run all tests on wasmtime
#   buck2 test //tests:wasmedge            - run wasip1 tests on wasmedge
#   buck2 test //tests:wazero              - run wasip1 tests on wazero
#   buck2 test //tests:wamr                - run wasip1 tests on wamr
#   buck2 test //tests/...                 - run all tests on all runtimes
#   buck2 build //tests:manifest           - generate manifest.json
#   buck2 build //tests:dist               - build distributable .tar.gz

load("//tools:conformance.bzl", "wasi_conformance_tests")
load("//tools:manifest.bzl", "dist_components", "dist_config_dirs", "dist_fixtures", "manifest_suites", "wasi_dist", "wasi_manifest")
load(":runtimes.bzl", "available_runtimes")

