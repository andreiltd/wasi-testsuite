_WASIP1_SUITES = {
    "c-wasip1": {
        "wasi_version": "wasm32-wasip1",
        "config_dir": "tests/c/src",
        "fixture_dir": "tests/c/src/fs-tests.dir",
        "component_prefix": "//tests/c",
        "component_suffix": "",
        "tests": _C_NAMES,
    },
    "rust-wasip1": {
        "wasi_version": "wasm32-wasip1",
        "config_dir": "tests/rust/wasm32-wasip1/src/bin",
        "fixture_dir": "tests/rust/wasm32-wasip1/src/bin/fs-tests.dir",
        "component_prefix": "//tests/rust/wasm32-wasip1",
        "component_suffix": "_component",
        "tests": _RUST_WASIP1_NAMES,
    },
    "assemblyscript-wasip1": {
        "wasi_version": "wasm32-wasip1",
        "config_dir": "tests/assemblyscript/wasm32-wasip1/src",
        "component_prefix": "//tests/assemblyscript/wasm32-wasip1",
        "component_suffix": "",
        "tests": _AS_NAMES,
    },
}

# Module-based suites for runtimes without component model support.
# These point at the raw rust_binary/cxx_binary (no _component suffix),
# and the conformance rule applies wasm_transition_p1 to compile for wasip1.
_WASIP1_MODULE_SUITES = {k: dict(v, component_suffix = "") for k, v in _WASIP1_SUITES.items()}

_WASIP3_SUITES = {
    "rust-wasip3": {
        "wasi_version": "wasm32-wasip3",
        "config_dir": "tests/rust/wasm32-wasip3/src/bin",
        "fixture_dir": "tests/rust/wasm32-wasip3/src/bin/fs-tests.dir",
        "component_prefix": "//tests/rust/wasm32-wasip3",
        "component_suffix": "_component",
        "tests": _RUST_WASIP3_NAMES,
    },
}

_ALL_SUITES = dict(_WASIP1_SUITES)
_ALL_SUITES.update(_WASIP3_SUITES)

# Wasmtime
wasi_conformance_tests(
    name = "wasmtime",
    adapter = "adapters/wasmtime.py",
    suites = _ALL_SUITES,
    runtime = "toolchains//:wasmtime_runtime",
    runtime_env_var = "WASMTIME",
    skip = [
        "cli-env",  # argv[0] mismatch in component vs module name
        "sockets-echo",  # timing-sensitive, flaky
        "http-service",  # timing-sensitive, flaky in parallel execution
        "filesystem-advise",  # fails on macOS (no posix_fadvise)
    ],
)

# Other runtimes (wasip1 modules, platform-dependent availability)
[
    wasi_conformance_tests(
        name = rt_name,
        adapter = rt_adapter,
        suites = _WASIP1_MODULE_SUITES,
        runtime = rt_target,
        runtime_env_var = rt_env,
    )
    for rt_name, rt_adapter, rt_target, rt_env in available_runtimes()
]

# All suites
wasi_manifest(name = "manifest", suites = manifest_suites(_ALL_SUITES))

wasi_dist(
    name = "dist",
    manifest = ":manifest",
    components = dist_components(_ALL_SUITES),
    config_dirs = dist_config_dirs(_ALL_SUITES),
    fixtures = dist_fixtures(_ALL_SUITES),
)

# Per WASI version
wasi_manifest(
    name = "manifest_wasip1",
    suites = manifest_suites(_WASIP1_SUITES),
)

wasi_manifest(
    name = "manifest_wasip3",
    suites = manifest_suites(_WASIP3_SUITES),
)

wasi_dist(
    name = "dist_wasip1",
    manifest = ":manifest_wasip1",
    components = dist_components(_WASIP1_SUITES),
    config_dirs = dist_config_dirs(_WASIP1_SUITES),
    fixtures = dist_fixtures(_WASIP1_SUITES),
)

wasi_dist(
    name = "dist_wasip3",
    manifest = ":manifest_wasip3",
    components = dist_components(_WASIP3_SUITES),
    config_dirs = dist_config_dirs(_WASIP3_SUITES),
    fixtures = dist_fixtures(_WASIP3_SUITES),
)
