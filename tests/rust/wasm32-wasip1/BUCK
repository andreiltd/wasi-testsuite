    {"name": "remove_directory_trailing_slashes", "dirs": _FS_DIRS, "skip": "TODO"},
    {"name": "remove_nonempty_directory", "dirs": _FS_DIRS},
    {"name": "renumber", "dirs": _FS_DIRS},
