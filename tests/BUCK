# Aggregation targets for running groups of tests.
# Usage:
#   buck2 test //tests/...            - all tests
#   buck2 test //tests:wasip1         - all wasip1 tests (C + Rust + AS)
#   buck2 test //tests:c              - C tests only
#   buck2 test //tests:rust_wasip1    - Rust wasip1 tests only
#   buck2 test //tests:assemblyscript - AssemblyScript tests only
#   buck2 test //tests:rust_wasip3    - Rust wasip3 tests (needs newer wasmtime)

_C_TESTS = [
    "//tests/c:clock_getres-monotonic_test",
    "//tests/c:clock_getres-realtime_test",
    "//tests/c:clock_gettime-monotonic_test",
    "//tests/c:clock_gettime-realtime_test",
    "//tests/c:fdopendir-with-access_test",
    "//tests/c:fopen-with-access_test",
    "//tests/c:fopen-with-no-access_test",
    "//tests/c:lseek_test",
    "//tests/c:pread-with-access_test",
    "//tests/c:pwrite-with-access_test",
    "//tests/c:pwrite-with-append_test",
    "//tests/c:sock_shutdown-invalid_fd_test",
    "//tests/c:sock_shutdown-not_sock_test",
    "//tests/c:stat-dev-ino_test",
]

