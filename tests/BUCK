test_suite(
    name = "c",
    tests = _C_TESTS,
)

test_suite(
    name = "rust_wasip1",
    tests = _RUST_WASIP1_TESTS,
)

test_suite(
    name = "assemblyscript",
    tests = _AS_TESTS,
)

test_suite(
    name = "rust_wasip3",
    tests = _RUST_WASIP3_TESTS,
)

test_suite(
    name = "wasip1",
    tests = _C_TESTS + _RUST_WASIP1_TESTS + _AS_TESTS,
)

test_suite(
    name = "all",
    tests = _C_TESTS + _RUST_WASIP1_TESTS + _AS_TESTS + _RUST_WASIP3_TESTS,
)
