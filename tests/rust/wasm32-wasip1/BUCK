    {"name": "fd_readdir", "dirs": _FS_DIRS},
    {"name": "file_allocate", "dirs": _FS_DIRS},
    {"name": "file_pread_pwrite", "dirs": _FS_DIRS},
    {"name": "file_seek_tell", "dirs": _FS_DIRS},
    {"name": "file_truncation", "dirs": _FS_DIRS},
    {"name": "file_unbuffered_write", "dirs": _FS_DIRS},
    {"name": "fstflags_validate", "dirs": _FS_DIRS},
    {"name": "interesting_paths", "dirs": _FS_DIRS},
    {"name": "isatty", "dirs": _FS_DIRS},
    {"name": "nofollow_errors", "dirs": _FS_DIRS},
    {"name": "overwrite_preopen", "dirs": _FS_DIRS},
    {"name": "path_exists", "dirs": _FS_DIRS},
    {"name": "path_filestat", "dirs": _FS_DIRS},
    {"name": "path_link", "dirs": _FS_DIRS},
