    {"name": "truncation_rights", "dirs": _FS_DIRS},
    {"name": "unlink_file_trailing_slashes", "dirs": _FS_DIRS},
]

# Shared test helper library
rust_library(
    name = "wasi_tests",
    crate = "wasi_tests",
    srcs = ["src/lib.rs", "src/config.rs"],
    edition = "2021",
    deps = [
        "//third-party:libc",
        "//third-party:once_cell",
        "//third-party:wasi",
    ],
    _cxx_toolchain = "toolchains//:rust_linker",
)

# Individual test binaries + components
[
    (
        rust_binary(
            name = t["name"],
            crate = t["name"],
            crate_root = "src/bin/{}.rs".format(t["name"]),
            srcs = ["src/bin/{}.rs".format(t["name"])],
            edition = "2021",
            deps = [
                ":wasi_tests",
                "//third-party:libc",
                "//third-party:wasi",
            ],
            _cxx_toolchain = "toolchains//:rust_linker",
        ),
        wasm_component(
            name = t["name"] + "_component",
            module = ":{}".format(t["name"]),
            adapter = "command",
        ),
    )
    for t in _TESTS
]

# wasm_test for each test
[
    wasm_test(
        name = t["name"] + "_test",
        component = ":{}_component".format(t["name"]),
        wasi_dirs = t.get("dirs", []),
        isolate_dirs = True,
        args = ["fs-tests.dir"] if t.get("dirs") else [],
    )
    for t in _TESTS
    if not t.get("skip")
]
