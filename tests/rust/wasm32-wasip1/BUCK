# Shared test helper library
rust_library(
    name = "wasi_tests",
    crate = "wasi_tests",
    srcs = ["src/lib.rs", "src/config.rs"],
    edition = "2021",
    default_target_platform = "//platforms:wasm32_wasi",
    deps = [
        "//third-party:libc",
        "//third-party:once_cell",
        "//third-party:wasi",
    ],
    _cxx_toolchain = "toolchains//:rust_linker",
)

# Individual test binaries + components
[
    (
        rust_binary(
            name = t,
            crate = t,
            crate_root = "src/bin/{}.rs".format(t),
            srcs = ["src/bin/{}.rs".format(t)],
            edition = "2021",
            default_target_platform = "//platforms:wasm32_wasi",
            visibility = ["//tests/..."],
            deps = [
                ":wasi_tests",
                "//third-party:libc",
                "//third-party:wasi",
            ],
            _cxx_toolchain = "toolchains//:rust_linker",
        ),
        wasm_component(
            name = t + "_component",
            module = ":{}".format(t),
            adapter = "command",
            visibility = ["//tests/..."],
        ),
    )
    for t in _TESTS
]
