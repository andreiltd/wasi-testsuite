load("@wasmono//toolchains/wasm:component.bzl", "wasm_component", "wasm_test")

# Rust wasip1 tests using native rust_binary + wasm_component + wasm_test.
#
# Shared test library + individual binaries per test, compiled to
# wasm32-wasip1 via the wasm_transition in wasm_component.

_FS_DIRS = ["tests/rust/wasm32-wasip1/src/bin/fs-tests.dir::fs-tests.dir"]

_TESTS = [
    {"name": "big_random_buf"},
    {"name": "clock_time_get"},
    {"name": "poll_oneoff_stdio"},
    {"name": "sched_yield"},
    {"name": "close_preopen", "dirs": _FS_DIRS},
    {"name": "dangling_fd", "dirs": _FS_DIRS},
    {"name": "dangling_symlink", "dirs": _FS_DIRS},
    {"name": "dir_fd_op_failures", "dirs": _FS_DIRS},
    {"name": "directory_seek", "dirs": _FS_DIRS},
    {"name": "fd_advise", "dirs": _FS_DIRS},
    {"name": "fd_fdstat_set_rights", "dirs": _FS_DIRS},
    {"name": "fd_filestat_set", "dirs": _FS_DIRS},
